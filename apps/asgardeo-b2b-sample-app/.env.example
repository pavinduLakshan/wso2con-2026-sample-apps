# Required: your Asgardeo organization base URL.
# Example: https://api.asgardeo.io/t/<your-organization-name>
NEXT_PUBLIC_ASGARDEO_BASE_URL=

# Required: the client ID from your Asgardeo application.
NEXT_PUBLIC_ASGARDEO_CLIENT_ID=client-id-of-your-asgardeo-application

# Required: the client secret from your Asgardeo application. Keep this server-side only.
ASGARDEO_CLIENT_SECRET=

NEXT_PUBLIC_ASGARDEO_SCOPES=

NEXT_PUBLIC_ASGARDEO_AFTER_SIGN_IN_URL=
NEXT_PUBLIC_ASGARDEO_AFTER_SIGN_OUT_URL=

# Required in production: a random secret used to protect app session cookies.
ASGARDEO_SECRET=

# Optional server-only overrides for the onboarding API.
# Prefer these over NEXT_PUBLIC_* values for client credentials calls.
# ASGARDEO_CLIENT_ID=<your-client-id>
ASGARDEO_PARENT_ORGANIZATION_ID=
ASGARDEO_ROOT_SCOPES=
ASGARDEO_ORG_SCOPES=
ASGARDEO_USER_STORE_NAME=
NEXT_PUBLIC_ASGARDEO_ADMIN_ROLE_NAME=
NEXT_PUBLIC_ASGARDEO_MEMBER_ROLE_NAME=
NEXT_PUBLIC_ASGARDEO_IDP_MANAGER_ROLE_NAME=
NEXT_PUBLIC_ASGARDEO_BASIC_BRANDING_EDITOR_ROLE_NAME=
NEXT_PUBLIC_ASGARDEO_ADVANCED_BRANDING_EDITOR_ROLE_NAME=
ASGARDEO_POLL_INTERVAL_MS=
ASGARDEO_USERSTORE_TIMEOUT_MS=
ASGARDEO_USER_CREATION_RETRY_TIMEOUT_MS=

# SQLite database file path. Defaults to ./data/app.db relative to project root.
# In production, set this to an absolute path outside the web root.
# DB_PATH=/var/data/app.db

# Optional AI assistant WebSocket endpoint.
NEXT_PUBLIC_AGENT_CHAT_URL=ws://localhost:8791/chat
