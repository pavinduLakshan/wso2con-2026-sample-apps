# Required: your Asgardeo organization base URL.
# Example: https://api.asgardeo.io/t/<your-organization-name>
NEXT_PUBLIC_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your-organization-name>

# Required: the client ID from your Asgardeo application.
NEXT_PUBLIC_ASGARDEO_CLIENT_ID=<your-client-id>

# Required: the client secret from your Asgardeo application. Keep this server-side only.
ASGARDEO_CLIENT_SECRET=<your-client-secret>

# Required in production: a random secret used to protect app session cookies.
ASGARDEO_SECRET=<your-random-session-secret>

# Optional server-only overrides for the onboarding API.
# Prefer these over NEXT_PUBLIC_* values for client credentials calls.
ASGARDEO_CLIENT_ID=<your-client-id>
ASGARDEO_ONBOARDING_PARENT_ORGANIZATION_ID=<your-parent-organization-id>
ASGARDEO_ONBOARDING_ROOT_SCOPES="internal_organization_create internal_organization_view internal_org_user_mgt_create internal_org_user_mgt_list"
ASGARDEO_ONBOARDING_ORG_SCOPES="internal_org_user_mgt_create internal_org_user_mgt_list"
ASGARDEO_ONBOARDING_USERSTORE_POLL_INTERVAL_MS=1500
ASGARDEO_ONBOARDING_USERSTORE_TIMEOUT_MS=30000
