# Required: your Asgardeo organization base URL.
# Example: https://api.asgardeo.io/t/<your-organization-name>
NEXT_PUBLIC_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/wayfinderenterprise

# Required: the client ID from your Asgardeo application.
NEXT_PUBLIC_ASGARDEO_CLIENT_ID=65dXNGfUbDbrbk5GtIHg58u6ojAa

# Required: the client secret from your Asgardeo application. Keep this server-side only.
ASGARDEO_CLIENT_SECRET=6aBdQXgXf__R8DjqXX9sUd6K_au8v4pyG6ApyH9xgMEa

NEXT_PUBLIC_ASGARDEO_SCOPES="openid profile email internal_org_user_mgt_create internal_org_user_mgt_update internal_org_user_mgt_list internal_org_role_mgt_users_update internal_org_role_mgt_view create_travel_policy view_travel_policy update_travel_policy delete_travel_policy"

NEXT_PUBLIC_ASGARDEO_AFTER_SIGN_IN_URL=http://localhost:3000
NEXT_PUBLIC_ASGARDEO_AFTER_SIGN_OUT_URL=http://localhost:3000

# Required in production: a random secret used to protect app session cookies.
ASGARDEO_SECRET=test

# Optional server-only overrides for the onboarding API.
# Prefer these over NEXT_PUBLIC_* values for client credentials calls.
# ASGARDEO_CLIENT_ID=<your-client-id>
ASGARDEO_PARENT_ORGANIZATION_ID=70880765-12c9-4921-a648-16d003a02345
ASGARDEO_ROOT_SCOPES="internal_organization_create internal_organization_view internal_org_user_mgt_create internal_org_user_mgt_list"
ASGARDEO_ORG_SCOPES="internal_org_user_mgt_create internal_org_user_mgt_list internal_org_userstore_view internal_org_role_mgt_view internal_org_role_mgt_update"
ASGARDEO_USER_STORE_NAME=DEFAULT
NEXT_PUBLIC_ASGARDEO_ADMIN_ROLE_NAME=WayFinder-Admin
NEXT_PUBLIC_ASGARDEO_MEMBER_ROLE_NAME=WayFinder-Member
NEXT_PUBLIC_ASGARDEO_IDP_MANAGER_ROLE_NAME=Idp-Manager
NEXT_PUBLIC_ASGARDEO_BASIC_BRANDING_EDITOR_ROLE_NAME=Basic-Branding-Editor
NEXT_PUBLIC_ASGARDEO_ADVANCED_BRANDING_EDITOR_ROLE_NAME=Advanced-Branding-Editor
ASGARDEO_POLL_INTERVAL_MS=1500
ASGARDEO_USERSTORE_TIMEOUT_MS=30000
ASGARDEO_USER_CREATION_RETRY_TIMEOUT_MS=30000

# SQLite database file path. Defaults to ./data/app.db relative to project root.
# In production, set this to an absolute path outside the web root.
# DB_PATH=/var/data/app.db
